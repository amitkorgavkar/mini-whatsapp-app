<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat Detail</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h2>Chat Detail</h2>
    <div class="chat">
        <p><strong>From:</strong> <%= chat.from %></p>
        <p><strong>To:</strong> <%= chat.to %></p>
        <p class="msg"><%= chat.msg %></p>
        <p><strong>Sent:</strong> <%= chat.created_at.toDateString() %></p>
    </div>
    <br>
    <a href="/chats">← Back to all chats</a>
</body>
</html>
